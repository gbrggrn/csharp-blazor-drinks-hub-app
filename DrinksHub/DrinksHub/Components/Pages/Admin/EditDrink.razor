@page "/editDrink/{Id:int}"
@rendermode InteractiveServer
@using DrinksHub.DTOs
@using DrinksHub.Services
@inject DrinksHubApiService ApiService
@inject NavigationManager NavManager

<div class="container mt-4">
    <h3>Edit Drink</h3>

    @if (isLoading)
    {
        <p>Loading drink details...</p>
    }
    else if (drinkModel == null)
    {
        <div class="alert alert-danger">Drink not found.</div>
        <button class="btn btn-secondary" @onclick="GoBack">Back to All Drinks</button>
    }
    else
    {
        <EditForm Model="drinkModel" OnValidSubmit="UpdateDrink">
            <DataAnnotationsValidator />
            <ValidationSummary />

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <div class="mb-3">
                <label class="form-label">Name</label>
                <InputText class="form-control" @bind-Value="drinkModel.Name" />
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <InputTextArea class="form-control" @bind-Value="drinkModel.Description" />
            </div>

            <div class="mb-3">
                <label class="form-label">Image URL</label>
                <InputText class="form-control" @bind-Value="drinkModel.ImageUrl" />
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Category</label>
                    <InputSelect class="form-select" @bind-Value="drinkModel.Category">
                        @foreach (var cat in Enum.GetValues<DrinkCategory>())
                        {
                            <option value="@cat">@cat</option>
                        }
                    </InputSelect>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Type</label>
                    <InputSelect class="form-select" @bind-Value="drinkModel.Type">
                        @foreach (var type in Enum.GetValues<DrinkType>())
                        {
                            <option value="@type">@type</option>
                        }
                    </InputSelect>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <button type="button" class="btn btn-secondary ms-2" @onclick="GoBack">Cancel</button>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private UpdateDrinkDTO? drinkModel;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var drinkToUpdate = await ApiService.GetDrinkByIdAsync(Id);

        if (drinkToUpdate != null)
        {
            drinkModel = new UpdateDrinkDTO
            {
                Name = drinkToUpdate.Name,
                Description = drinkToUpdate.Description,
                ImageUrl = drinkToUpdate.ImageUrl,
                Category = drinkToUpdate.Category,
                Type = drinkToUpdate.Type
            };
        }

        isLoading = false;
    }

    private async Task UpdateDrink()
    {
        bool success = await ApiService.UpdateDrinkAsync(Id, drinkModel!);

        if (success)
        {
            NavManager.NavigateTo("/");
        }
        else
        {
            errorMessage = "Failed to Edit.";
        }
    }

    private void GoBack()
    {
        NavManager.NavigateTo("/");
    }
}